---
import { buildHtmlPages } from "../lib/content.mjs";

export async function getStaticPaths() {
  const pages = await buildHtmlPages();
  return pages.map((page) => ({
    params: {
      route: page.url === "/"
        ? undefined
        : page.url === "/404.html"
          ? "404.html"
          : page.url.replace(/^\/|\/$/g, "")
    },
    props: { html: page.html }
  }));
}

const { html } = Astro.props;
---
<Fragment set:html={html} />
